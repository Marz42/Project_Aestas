# App
APP_NAME=aestas
ENVIRONMENT=development
API_KEY=dev-api-key-change-me

# Database (docker-compose defaults)
DATABASE_URL=postgresql+asyncpg://aestas:aestas@localhost:5432/aestas
DATABASE_URL_SYNC=postgresql+psycopg2://aestas:aestas@localhost:5432/aestas

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Scheduling (minutes / hours)
FETCH_INTERVAL_MINUTES=480
BRIEF_WINDOW_HOURS=8

# M1 heartbeat interval for verifying Beat (seconds)
CELERY_HEARTBEAT_INTERVAL_SECONDS=60

# DeepSeek (M3+)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
